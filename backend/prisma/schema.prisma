generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Asset {
  id           Int       @id @default(autoincrement())
  name         String    @db.VarChar(255)
  type         String    @db.VarChar(255)
  siteId       Int?      @map("site_id")
  manufacturer String    @db.VarChar(500)
  year         Int
  quickFixes   Int       @map("quick_fixes")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime? @updatedAt @map("updated_at")
  site         Site?     @relation(fields: [siteId], references: [id], onDelete: Restrict)
  jobs         Job[]

  @@index([siteId])
  @@map("assets")
}

model Site {
  id         Int       @id @default(autoincrement())
  code       String    @unique @db.VarChar(50)
  name       String    @db.VarChar(255)
  location   String    @db.VarChar(255)
  entity     String
  category   String
  budget     Float
  isFavorite Boolean   @default(false) @map("is_favorite")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime? @updatedAt @map("updated_at")
  assets     Asset[]
  jobs       Job[]
  user       User[]

  @@map("sites")
}

model Job {
  id          Int       @id @default(autoincrement())
  reference   Int
  description String    @db.VarChar(500)
  cost        Float
  status      Status    @default(PENDING)
  siteId      Int?      @map("site_id")
  assetId     Int?      @map("asset_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime? @updatedAt @map("updated_at")
  asset       Asset?    @relation(fields: [assetId], references: [id])
  site        Site?     @relation(fields: [siteId], references: [id])

  @@index([siteId])
  @@index([assetId])
  @@map("jobs")
}

model User {
  id                Int      @id @default(autoincrement())
  email             String   @unique
  name              String   @db.VarChar(255)
  password          String   @db.VarChar(255)
  role              Role     @default(USER)
  siteId            Int?     @map("site_id")

  resetPasswordToken   String?     
  resetPasswordExpires DateTime? 
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  gender             Gender   @default(GUY)
  isVerified         Boolean  @default(false)
  verificationToken  String?
  site               Site?    @relation(fields: [siteId], references: [id])

  @@index([siteId])
  @@map("users")
}

enum Gender {
  GUY
  GIRL
  NEUTRAL
}

enum Role {
  USER
  ADMIN
}

enum Status {
  PENDING
  CLOSED_NOT_AS_REPORTED
  HOLDING_TANK
  CONTRACT_ON_SITE
  CONTRACT_VISIT_ARRANGED
  CONTRACTOR_FINISHED
  COMPLETE_AS_REPORTED
  JOB_APPROVED
  LOGGED_WITH_NBS
}
