{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",        
    "moduleResolution": "Node10",        
    "ignoreDeprecations": "6.0",
    "rootDir": "src",
    "outDir": "dist",
    "strict": true,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["src"]
}