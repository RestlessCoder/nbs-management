{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",        
    "moduleResolution": "Node10",        
    "ignoreDeprecations": "6.0",
    "rootDir": "src",
    "outDir": "dist",
    "strict": true,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "typeRoots": ["./src/types", "./node_modules/@types"]
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}